NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GEMINI_API_KEY=
DEEPGRAM_API_KEY=

# AI_FAST_MODEL: used for latency-sensitive live-meeting speaker/translation batches
# (must return in a few seconds). AI_QUALITY_MODEL: used for background, no-latency-pressure
# passes (post-meeting full-context polish, summaries, upload/YouTube pipeline steps 1-3).
# Keep these genuinely different models — if they're equal, the background "polish" pass
# only gains from more context, not from a stronger model.
AI_FAST_MODEL=gemini-3.1-flash-lite
AI_QUALITY_MODEL=gemini-2.5-pro
